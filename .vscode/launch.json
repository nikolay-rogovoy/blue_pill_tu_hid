{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Blue Pill (External)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/blue-pill.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:3333",
            "gdbPath": "/usr/bin/gdb-multiarch",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "svdFile": "${workspaceFolder}/.vscode/STM32F103xx.svd"
        }
    ]
}